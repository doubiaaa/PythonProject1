FROM node:18-alpine

WORKDIR /app/frontend

# 复制前端依赖文件
COPY frontend/package.json frontend/package-lock.json ./

# 安装前端依赖
RUN npm install --legacy-peer-deps

# 复制前端源代码
COPY frontend/ ./

# 构建前端
RUN npm run build

# 安装 serve 用于 serve 前端静态文件
RUN npm install -g serve

# 暴露端口
EXPOSE 3000

# 启动命令
CMD ["serve", "-s", "dist", "-l", "3000"]
